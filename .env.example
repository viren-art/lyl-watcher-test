# Database
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5432
TIMESCALEDB_DATABASE=weather_db
TIMESCALEDB_USER=postgres
TIMESCALEDB_PASSWORD=your_secure_password
TIMESCALEDB_SSL=true
TIMESCALEDB_SSL_CA_CERT=/path/to/ca-cert.pem
TIMESCALEDB_SSL_CLIENT_CERT=/path/to/client-cert.pem
TIMESCALEDB_SSL_CLIENT_KEY=/path/to/client-key.pem

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=true
KAFKA_SSL_CA_CERT=/path/to/kafka-ca-cert.pem
KAFKA_SSL_CLIENT_CERT=/path/to/kafka-client-cert.pem
KAFKA_SSL_CLIENT_KEY=/path/to/kafka-client-key.pem
KAFKA_SASL_ENABLED=true
KAFKA_USERNAME=kafka_user
KAFKA_PASSWORD=kafka_secure_password

# Encryption (AES-256-GCM with PBKDF2 key derivation)
MASTER_ENCRYPTION_KEY=your_minimum_32_character_master_key_here_change_in_production
ENCRYPTION_KEY_VERSION=1
KEY_ROTATION_DATE=2024-01-15T00:00:00Z

# Weather APIs
NOAA_API_URL=https://api.weather.gov
OPENWEATHER_API_KEY=your_openweather_api_key

# Python
PYTHON_PATH=python3
MODEL_PATH=models/weather_lstm_best.h5

# Server
PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=https://dashboard.example.com,https://api.example.com

# Logging
LOG_LEVEL=info