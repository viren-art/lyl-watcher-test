# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grid_ai_platform
DB_USER=postgres
DB_PASSWORD=your_secure_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars

# MFA Encryption Key (32 bytes hex)
MFA_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@gridai.platform
ADMIN_EMAIL=admin@gridai.platform

# Application Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000

# Session Configuration
SESSION_SECRET=your_session_secret_key
SESSION_TIMEOUT=3600000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json